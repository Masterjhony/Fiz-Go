# Database Configuration
DATABASE_URL=postgresql://fizgo_user:fizgo_password@localhost:5432/fizgo
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fizgo_user
DB_PASSWORD=fizgo_password
DB_DATABASE=fizgo

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Server Configuration
NODE_ENV=development
PORT=3000

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=./uploads

# Payment Configuration (PIX)
PIX_PROVIDER_URL=https://api.payment-provider.com
PIX_API_KEY=your-pix-api-key
PIX_WEBHOOK_SECRET=your-pix-webhook-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Frontend URL
FRONTEND_URL=http://localhost:8080

# Admin Configuration
ADMIN_EMAIL=admin@fizgo.com
ADMIN_PASSWORD=admin123  # Change in production