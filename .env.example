# ==============================================
# Fiz-Go - Configurações de Ambiente
# ==============================================

# ----- Aplicação Principal -----
NODE_ENV=development
PORT=3000
APP_NAME="Fiz-Go"
APP_VERSION=1.0.0

# ----- Banco de Dados -----
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fizgo_user
DB_PASSWORD=fizgo_password
DB_DATABASE=fizgo_db

# URL de conexão completa (alternativa)
DATABASE_URL=postgresql://fizgo_user:fizgo_password@localhost:5432/fizgo_db

# ----- Redis (Cache & Sessions) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- Autenticação JWT -----
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_REFRESH_EXPIRES_IN=7d

# ----- OAuth Social Login -----
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Apple OAuth (se implementado)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-private-key.p8

# ----- Sistema de Pagamentos -----
# PIX Configuration
PIX_CLIENT_ID=your-pix-client-id
PIX_CLIENT_SECRET=your-pix-client-secret
PIX_CERTIFICATE_PATH=./certificates/pix-cert.p12
PIX_CERTIFICATE_PASSWORD=your-cert-password

# Webhook para notificações PIX
PIX_WEBHOOK_URL=https://yourdomain.com/webhooks/pix

# ----- Geolocalização -----
# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapbox (alternativa)
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# ----- Storage e Upload -----
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=fizgo-uploads

# Cloudinary (alternativa)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ----- Notificações -----
# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@fizgo.com.br
SENDGRID_FROM_NAME=Fiz-Go

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+5511999999999

# ----- Monitoramento e Logs -----
# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=your-newrelic-license-key
NEW_RELIC_APP_NAME=fizgo-backend

# ----- WebSocket (Chat) -----
WS_PORT=3001
WS_CORS_ORIGIN=http://localhost:3000

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100  # máximo de requests por window

# ----- Segurança -----
# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# Helmet Security Headers
HELMET_ENABLED=true

# ----- Sistema de Agentes de IA -----
# Paths para o sistema de agentes (relativo ao backend)
AGENTS_LOG_PATH=../agents/agent_log.jsonl
AGENTS_STATE_PATH=../agents/agent_state.json
AGENTS_ENABLED=true

# ----- Desenvolvimento -----
# Debug
DEBUG=fizgo:*
LOG_LEVEL=debug

# Hot Reload
CHOKIDAR_USEPOLLING=true

# ----- Testes -----
# Banco de dados de teste
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USERNAME=fizgo_test
TEST_DB_PASSWORD=fizgo_test_password
TEST_DB_DATABASE=fizgo_test_db

# ----- Docker -----
# Postgres Docker
POSTGRES_USER=fizgo_user
POSTGRES_PASSWORD=fizgo_password
POSTGRES_DB=fizgo_db

# Redis Docker
REDIS_PASSWORD_DOCKER=

# ----- Mobile (Flutter) -----
# API Base URL para o app mobile
API_BASE_URL=http://localhost:3000/api
WS_BASE_URL=ws://localhost:3001

# Deep Links
DEEP_LINK_SCHEME=fizgo
DEEP_LINK_HOST=app.fizgo.com.br

# ----- Produção -----
# URLs de produção (substituir em produção)
# PRODUCTION_API_URL=https://api.fizgo.com.br
# PRODUCTION_WS_URL=wss://ws.fizgo.com.br
# PRODUCTION_WEB_URL=https://fizgo.com.br

# CDN
# CDN_BASE_URL=https://cdn.fizgo.com.br

# ----- Backup e Manutenção -----
# Backup automático
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *  # Todo dia às 2h
BACKUP_S3_BUCKET=fizgo-backups

# ----- Ferramentas de Desenvolvimento -----
# Swagger/OpenAPI
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# GraphQL Playground (se implementado)
GRAPHQL_PLAYGROUND_ENABLED=true

# ----- Features Flags -----
FEATURE_CHAT_ENABLED=true
FEATURE_PAYMENTS_ENABLED=true
FEATURE_GEOLOCATION_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_PUSH_NOTIFICATIONS_ENABLED=true

# ==============================================
# NOTAS IMPORTANTES:
# ==============================================
# 1. NUNCA comite este arquivo com valores reais
# 2. Altere todas as chaves secretas em produção
# 3. Use gerenciadores de segredos em produção (AWS Secrets Manager, etc.)
# 4. Mantenha variáveis sensíveis em arquivos separados por ambiente
# 5. Valide todas as variáveis no startup da aplicação